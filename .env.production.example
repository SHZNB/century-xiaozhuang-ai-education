PORT=8080
NODE_ENV=production
DEMO_MODE=false
DATA_DIR=/data
MODEL_MAX_OUTPUT_TOKENS=8192
FRONTEND_ORIGINS=
PUBLIC_FRONTEND_URL=
COOKIE_SAMESITE=Strict

# Production admin bootstrap account.
# Replace before first deployment, then rotate to the school SSO or a dedicated admin account.
DEV_ADMIN_USERNAME=
DEV_ADMIN_PASSWORD=
SESSION_SECRET=

# School unified identity / OIDC.
# Keep SSO_ENABLED=false until the identity provider callback URL is registered.
SSO_ENABLED=false
SSO_LOGIN_LABEL=学校统一身份认证登录
SSO_ISSUER=
SSO_AUTHORIZATION_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_SCOPE=openid profile email
SSO_USERNAME_CLAIM=preferred_username
SSO_DISPLAY_NAME_CLAIM=name
SSO_DEPARTMENT_CLAIM=department
SSO_DEFAULT_ROLE=teacher

# Alumni association joint verification.
# Leave empty only when the platform is still using manual alumni review.
ALUMNI_ASSOCIATION_VERIFY_URL=
ALUMNI_ASSOCIATION_API_KEY=

# Kimi / Moonshot: long text, PDF, long context.
MOONSHOT_API_KEY=
MOONSHOT_API_URL=https://api.moonshot.cn/v1/chat/completions
MOONSHOT_MODEL=moonshot-v1-32k

# DeepSeek: lesson plans, curriculum design, teaching evaluation.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Qwen: general Chinese education tasks.
QWEN_API_KEY=
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus

# ChatGPT: PPT outlines, speech scripts, HTML presentations.
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-5

# Gemini: image understanding.
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.5-flash

# Coze Workflow: HTML pages and interactive animation.
COZE_API_KEY=
COZE_API_URL=
COZE_WORKFLOW_ID=

# Optional domestic providers and fallbacks.
DOUBAO_API_KEY=
DOUBAO_API_URL=
DOUBAO_MODEL=
GLM_API_KEY=
GLM_API_URL=
GLM_MODEL=
ERNIE_API_KEY=
ERNIE_API_URL=
ERNIE_MODEL=
HUNYUAN_API_KEY=
HUNYUAN_API_URL=
HUNYUAN_MODEL=
