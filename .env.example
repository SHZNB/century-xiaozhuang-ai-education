PORT=8080
NODE_ENV=development
DEMO_MODE=false
DATA_DIR=./server/data
MODEL_MAX_OUTPUT_TOKENS=8192
FRONTEND_ORIGINS=
PUBLIC_FRONTEND_URL=
COOKIE_SAMESITE=Strict

# 校友会联合认证接口。未配置时自动回退人工审核。
ALUMNI_ASSOCIATION_VERIFY_URL=
ALUMNI_ASSOCIATION_API_KEY=

# 开发管理员账号。生产环境必须改强密码，并尽快接入学校统一身份认证。
DEV_ADMIN_USERNAME=xz2026
DEV_ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-random-32-plus-character-secret

# 学校统一身份认证 OIDC。未配置时继续使用本地平台账号登录。
SSO_ENABLED=false
SSO_LOGIN_LABEL=学校统一身份认证登录
SSO_ISSUER=
SSO_AUTHORIZATION_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_SCOPE=openid profile email
SSO_USERNAME_CLAIM=preferred_username
SSO_DISPLAY_NAME_CLAIM=name
SSO_DEPARTMENT_CLAIM=department
SSO_DEFAULT_ROLE=teacher

# Kimi / Moonshot：长文本、PDF、长上下文
MOONSHOT_API_KEY=
MOONSHOT_API_URL=https://api.moonshot.cn/v1/chat/completions
MOONSHOT_MODEL=moonshot-v1-32k

# DeepSeek：教案、课程设计、教学评价
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 通义千问：中文通用任务
QWEN_API_KEY=
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus

# OpenAI / ChatGPT：PPT、讲稿、HTML 演示
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-5

# Gemini：图片理解
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.5-flash

# Coze Workflow：HTML 网页与交互动画
COZE_API_KEY=
COZE_API_URL=
COZE_WORKFLOW_ID=

# 其他国产模型。采用 OpenAI 兼容接口时填写 URL 和模型名。
DOUBAO_API_KEY=
DOUBAO_API_URL=
DOUBAO_MODEL=
GLM_API_KEY=
GLM_API_URL=
GLM_MODEL=
ERNIE_API_KEY=
ERNIE_API_URL=
ERNIE_MODEL=
HUNYUAN_API_KEY=
HUNYUAN_API_URL=
HUNYUAN_MODEL=
